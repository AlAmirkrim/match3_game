# Auto detect text files and perform LF normalization
* text=auto

# Binary files - never convert line endings or diff as text
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.bmp binary
*.tiff binary
*.tif binary
*.svg binary

# Fonts
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.eot binary

# Archives
*.zip binary
*.jar binary
*.aar binary

# Flutter/Dart specific
*.so binary
*.dylib binary
*.dll binary

# Android specific
*.apk binary
*.aab binary
*.keystore binary
*.jks binary
